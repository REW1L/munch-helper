{
  "expo": {
    "name": "Munch Helper",
    "slug": "munch-helper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/munchkin-cat.png",
    "scheme": "munchhelper",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.munch-helper"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.munchhelper"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.ico"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/shopkeeper.png",
          "imageWidth": 100
        }
      ],
      "expo-navigation-bar",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}